# ─────────────────────────────────────────────
# Salesforce Credentials
# ─────────────────────────────────────────────
SF_USERNAME=your.email@example.com
SF_PASSWORD=yourSalesforcePassword
SF_SECURITY_TOKEN=yourSecurityToken
SF_CONSUMER_KEY=your_connected_app_consumer_key
SF_CONSUMER_SECRET=your_connected_app_consumer_secret
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_API_VERSION=63.0

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=salesforce_backup
POSTGRES_USER=sfuser
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_SSLMODE=require

# ─────────────────────────────────────────────
# Sync Configuration
# ─────────────────────────────────────────────
# Account: pulled with WHERE Type IN ('Resume', 'Job Application')
# Contact: pulled with WHERE AccountId IN (synced account IDs)
# Custom objects below are pulled in full (all records).
# Object list is hardcoded in src/sync.py — edit there to add/remove objects.

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# How often to sync (in seconds). Default: 86400 (once per day)
SYNC_INTERVAL_SECONDS=86400
